# Set these in your host’s environment (e.g. Vercel → Settings → Environment Variables).
# Next.js loads them server-side at runtime; a local .env.local file is optional for `next dev` only.

# MongoDB Atlas Connection String
# Replace YOUR_PASSWORD with your actual MongoDB password
MONGODB_URI=mongodb+srv://username:YOUR_PASSWORD@cluster.xxxxx.mongodb.net/sdhq?retryWrites=true&w=majority

# Server-to-server authentication (webhooks / OAuth callback → /api/activity-log; optional cron → POST /api/algorithms/update).
# Send HTTP header on those requests: x-internal-api-secret=<same value>
INTERNAL_API_SECRET=your_long_random_secret

# Cloudflare R2 Storage Configuration (for video uploads)
# Get these from your Cloudflare R2 dashboard: https://dash.cloudflare.com/
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=sdhq-uploads

# --- PayPal: master switch ---
# Only the exact string `sandbox` uses PayPal Sandbox (test money). Use `live` for real payments (production).
# NEXT_PUBLIC_PAYPAL_MODE is read first (browser + server). Redeploy after changing NEXT_PUBLIC_* (baked in at build).
# Vercel Production should set: NEXT_PUBLIC_PAYPAL_MODE=live with live Client ID, PAYPAL_CLIENT_SECRET, NEXT_PUBLIC_PAYPAL_PLAN_ID.
NEXT_PUBLIC_PAYPAL_MODE=live

# Optional duplicate for scripts/CI only. Do NOT set PAYPAL_MODE=live while NEXT_PUBLIC_PAYPAL_MODE=sandbox.
# PAYPAL_MODE=sandbox

# Live REST credentials (production app at developer.paypal.com)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Sandbox REST credentials (sandbox app — different client ID/secret than live)
PAYPAL_CLIENT_ID_SANDBOX=your_sandbox_client_id
PAYPAL_CLIENT_SECRET_SANDBOX=your_sandbox_client_secret

# Browser PayPal JS SDK — live vs sandbox client IDs (must match NEXT_PUBLIC_PAYPAL_MODE)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
NEXT_PUBLIC_PAYPAL_CLIENT_ID_SANDBOX=your_sandbox_client_id

# Subscription plan IDs — Billing Plan ID starts with P- (create under same REST app as Client ID). NOT PROD-...
# In sandbox, set NEXT_PUBLIC_PAYPAL_PLAN_ID_SANDBOX to a plan created with your *sandbox* app (or run: npm run create-paypal-plan with PAYPAL_MODE=sandbox).
# If only NEXT_PUBLIC_PAYPAL_PLAN_ID is set (live plan) and mode is sandbox, Subscribe will show RESOURCE_NOT_FOUND.
NEXT_PUBLIC_PAYPAL_PLAN_ID=P-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_PAYPAL_PLAN_ID_SANDBOX=P-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# In-progress “New tool” tab + /api/new-tool — omit on production until release. Local/preview: NEXT_PUBLIC_SHOW_NEW_TOOL_TAB=1
# NEXT_PUBLIC_SHOW_NEW_TOOL_TAB=1

# Google Gemini (tag generator default; optional thumbnail prompt enrich below)
# GEMINI_API=your_google_ai_studio_key

# --- Provider toggles (one variable per feature) ---
# Thumbnails: gemini (default), fal_kontext, fal_nano_edit
THUMBNAIL_GENERATOR_BACKEND=gemini
# Tags: gemini (default) or fal (Fal OpenRouter LLM)
TAG_GENERATOR_BACKEND=gemini
# Clip analyzer: gemini (default; current supported backend)
CLIP_ANALYZER_BACKEND=gemini

# Thumbnails: Fal (`FAL_KEY` preferred; `SCHNELL_API_KEY` kept as legacy alias in some routes). Defaults: FLUX — T2I fal-ai/flux-2/turbo; uploads fal-ai/flux-2/turbo/edit.
# Faster/cheaper FLUX.2: FAL_THUMBNAIL_TXT2IMG_MODEL=fal-ai/flux-2/flash and FAL_THUMBNAIL_IMG2IMG_MODEL=fal-ai/flux-2/flash/edit (or set only one — paired automatically).
# Smart Gemini image on Fal: FAL_THUMBNAIL_IMAGE_STACK=nano_banana_pro → fal-ai/nano-banana-pro + fal-ai/nano-banana-pro/edit (optional: FAL_THUMBNAIL_NANO_PRO_RESOLUTION=1K|2K|4K, FAL_THUMBNAIL_NANO_PRO_WEB_SEARCH=1). Per-role overrides unchanged: FAL_THUMBNAIL_TXT2IMG_MODEL=..., FAL_THUMBNAIL_IMG2IMG_MODEL=... (e.g. fal-ai/nano-banana / fal-ai/nano-banana/edit for cheaper Flash tier).
# THUMBNAIL_GEMINI_ENRICH=1
# With GEMINI_API set, Gemini 2.5 spellchecks creator notes before Fal (default on). Disable: THUMBNAIL_GEMINI_SPELLCHECK=0
# THUMBNAIL_GEMINI_MODEL=gemini-2.5-flash
# Optional branding mode: include recognizable platform/game logos when detected from prompt/platforms.
# THUMBNAIL_ALLOW_BRAND_LOGOS=1
# FAL_THUMBNAIL_FLUX2_PROMPT_EXPANSION=1
# FAL_THUMBNAIL_FLUX2_GUIDANCE_SCALE=2.5
# Optional speed: FAL_THUMBNAIL_OUTPUT_FORMAT=jpeg (smaller/faster than png default). FAL_THUMBNAIL_FLUX2_PROMPT_EXPANSION=0 skips Fal-side expansion latency on FLUX.2 Turbo.
# Optional (FLUX only): FAL_THUMBNAIL_ENABLE_SAFETY_CHECKER=0 may reduce inference time — weaker moderation.

# Tag generator: `gemini` (default, direct Google) or `fal` (LLM via Fal OpenRouter). FLUX Schnell is text-to-image only — use OpenRouter model ids for hashtags.
# TAG_GENERATOR_BACKEND=gemini
# SCHNELL_API_KEY=your_fal_key
# FAL_KEY=your_fal_key
# FAL_TAG_LLM_MODEL=google/gemini-2.5-flash

# Optional: tweak ~USD hints in owner Activity Feed (thumbnail / tags / clip analyze). Defaults in src/lib/estimatedInferenceCost.ts
# ESTIMATE_FLUX_USD_PER_MP=0.008
# ESTIMATE_FLUX2_FLASH_USD_PER_MP=0.005
# ESTIMATE_NANO_FLASH_USD=0.039
# ESTIMATE_NANO_PRO_1K2K_USD=0.15
# ESTIMATE_NANO_PRO_4K_USD=0.30
# ESTIMATE_THUMBNAIL_GEMINI_ENRICH_USD=0.0005
# ESTIMATE_THUMBNAIL_GEMINI_SPELLCHECK_USD=0.0002
# ESTIMATE_TAG_GEMINI_USD=0.0002
# ESTIMATE_TAG_FAL_OPENROUTER_USD=0.0004
# ESTIMATE_CLIP_ANALYSIS_USD=0.025

# API Keys for Content Analysis
GROQ_API_KEY=your_groq_api_key
RAPID_API_KEY=your_rapidapi_key
SUPADATA_API_KEY=your_supadata_api_key
POLLINATIONS_API_KEY=your_pollinations_api_key

# OpenAI API Key (optional - for premium tier)
OPENAI_API_KEY=your_openai_api_key_here

# Google API Key (optional - for entity extraction)
GOOGLE_API_KEY=your_google_api_key_here

# Resend — staff email when users submit Contact staff (Settings); same pattern as above (host env).
# https://resend.com/api-keys — verify your domain for RESEND_FROM_EMAIL in production
RESEND_API_KEY=re_xxxxxxxx
# Optional: defaults to bulletbait604@gmail.com
# FEEDBACK_NOTIFY_EMAIL=you@example.com
# Optional: must be from a domain verified in Resend (defaults to Resend sandbox sender)
# RESEND_FROM_EMAIL=Stream Dreams <noreply@yourdomain.com>
