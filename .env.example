# Set these in your host’s environment (e.g. Vercel → Settings → Environment Variables).
# Next.js loads them server-side at runtime; a local .env.local file is optional for `next dev` only.

# MongoDB Atlas Connection String
# Replace YOUR_PASSWORD with your actual MongoDB password
MONGODB_URI=mongodb+srv://username:YOUR_PASSWORD@cluster.xxxxx.mongodb.net/sdhq?retryWrites=true&w=majority

# Server-to-server authentication (webhooks / OAuth callback → /api/activity-log; optional cron → POST /api/algorithms/update).
# Send HTTP header on those requests: x-internal-api-secret=<same value>
INTERNAL_API_SECRET=your_long_random_secret

# Cloudflare R2 Storage Configuration (for video uploads)
# Get these from your Cloudflare R2 dashboard: https://dash.cloudflare.com/
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=sdhq-uploads

# --- PayPal: master switch ---
# Only the exact string `sandbox` uses PayPal Sandbox (test money). Use `live` for real payments (production).
# NEXT_PUBLIC_PAYPAL_MODE is read first (browser + server). Redeploy after changing NEXT_PUBLIC_* (baked in at build).
# Vercel Production should set: NEXT_PUBLIC_PAYPAL_MODE=live with live Client ID, PAYPAL_CLIENT_SECRET, NEXT_PUBLIC_PAYPAL_PLAN_ID.
NEXT_PUBLIC_PAYPAL_MODE=live

# Optional duplicate for scripts/CI only. Do NOT set PAYPAL_MODE=live while NEXT_PUBLIC_PAYPAL_MODE=sandbox.
# PAYPAL_MODE=sandbox

# Live REST credentials (production app at developer.paypal.com)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Sandbox REST credentials (sandbox app — different client ID/secret than live)
PAYPAL_CLIENT_ID_SANDBOX=your_sandbox_client_id
PAYPAL_CLIENT_SECRET_SANDBOX=your_sandbox_client_secret

# Browser PayPal JS SDK — live vs sandbox client IDs (must match NEXT_PUBLIC_PAYPAL_MODE)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
NEXT_PUBLIC_PAYPAL_CLIENT_ID_SANDBOX=your_sandbox_client_id

# Subscription plan IDs — Billing Plan ID starts with P- (create under same REST app as Client ID). NOT PROD-...
# In sandbox, set NEXT_PUBLIC_PAYPAL_PLAN_ID_SANDBOX to a plan created with your *sandbox* app (or run: npm run create-paypal-plan with PAYPAL_MODE=sandbox).
# If only NEXT_PUBLIC_PAYPAL_PLAN_ID is set (live plan) and mode is sandbox, Subscribe will show RESOURCE_NOT_FOUND.
NEXT_PUBLIC_PAYPAL_PLAN_ID=P-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_PAYPAL_PLAN_ID_SANDBOX=P-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# In-progress “New tool” tab + /api/new-tool — omit on production until release. Local/preview: NEXT_PUBLIC_SHOW_NEW_TOOL_TAB=1
# NEXT_PUBLIC_SHOW_NEW_TOOL_TAB=1

# Google Gemini (tag generator default; optional thumbnail prompt enrich below)
# GEMINI_API=your_google_ai_studio_key

# --- Thumbnail generator ---
# Default: Gemini 2.5 Flash research + gemini-2.5-flash-image paint (no Fal).
# Required: GEMINI_API, R2 + MongoDB for full features.
THUMBNAIL_GENERATOR_BACKEND=gemini
# Optional overrides:
# THUMBNAIL_GEMINI_MODEL=gemini-2.5-flash
# THUMBNAIL_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# THUMBNAIL_GEMINI_THINKING_LEVEL=MEDIUM
# THUMBNAIL_GEMINI_SPELLCHECK=0
# THUMBNAIL_ALLOW_BRAND_LOGOS=1
# FAL_THUMBNAIL_NANO_PRO_RESOLUTION=1K
# FAL_THUMBNAIL_IMAGE_STACK=flux
# Legacy Fal paint path: THUMBNAIL_GENERATOR_BACKEND=fal (+ FAL_KEY)

# Tags: gemini (default) or fal (Fal OpenRouter LLM)
TAG_GENERATOR_BACKEND=gemini
# Clip analyzer: gemini (default; current supported backend)
CLIP_ANALYZER_BACKEND=gemini

# Fal key for thumbnail paint + optional tag backend.
# FAL_KEY=your_fal_key
# TAG_GENERATOR_BACKEND=gemini
# SCHNELL_API_KEY=your_fal_key
# FAL_KEY=your_fal_key
# FAL_TAG_LLM_MODEL=google/gemini-2.5-flash

# Optional: tweak ~USD hints in owner Activity Feed (thumbnail / tags / clip analyze). Defaults in src/lib/estimatedInferenceCost.ts
# ESTIMATE_FLUX_USD_PER_MP=0.008
# ESTIMATE_FLUX2_FLASH_USD_PER_MP=0.005
# ESTIMATE_NANO_FLASH_USD=0.039
# ESTIMATE_NANO_PRO_1K2K_USD=0.15
# ESTIMATE_NANO_PRO_4K_USD=0.30
# ESTIMATE_THUMBNAIL_GEMINI_ENRICH_USD=0.0005
# ESTIMATE_THUMBNAIL_GEMINI_SPELLCHECK_USD=0.0002
# ESTIMATE_TAG_GEMINI_USD=0.0002
# ESTIMATE_TAG_FAL_OPENROUTER_USD=0.0004
# ESTIMATE_CLIP_ANALYSIS_USD=0.025

# API Keys for Content Analysis
RAPID_API_KEY=your_rapidapi_key

# Clip Editor — Opus/StreamLadder multi-pass (100% cloud, no local worker)
# Browser → R2; Vercel enqueues steps via Upstash QStash; each step runs on Vercel serverless.
# Create free QStash at https://console.upstash.com/qstash
QSTASH_TOKEN=your_qstash_token
QSTASH_CURRENT_SIGNING_KEY=your_current_signing_key
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key
# QStash region (defaults to US in code if unset). EU only: QSTASH_URL=https://qstash-eu-central-1.upstash.io
QSTASH_URL=https://qstash-us-east-1.upstash.io
# Public URL QStash calls back (production). On Vercel, VERCEL_URL is used if unset.
CLIP_EDITOR_APP_URL=https://your-app.vercel.app
# Clip Editor quality: fast | standard | max (default standard). Redeploy after changing.
CLIP_EDITOR_QUALITY_TIER=standard
# CLIP_EDITOR_GEMINI_MODEL=gemini-2.5-flash
# Optional cost estimate overrides (USD): ESTIMATE_CLIP_EDITOR_DEEPGRAM_PER_MIN, ESTIMATE_CLIP_EDITOR_GEMINI_VIDEO_USD,
# ESTIMATE_CLIP_EDITOR_GEMINI_VIDEO_PER_MIN, ESTIMATE_CLIP_EDITOR_GEMINI_TEXT_USD, ESTIMATE_CLIP_EDITOR_SHOTSTACK_RENDER_USD
# OPENAI_API_KEY=optional_fallback_when_gemini_errors
# R2_PUBLIC_BASE_URL=https://your-cdn.example.com

# Clip Editor AI stack:
# - Gemini / Google AI Studio: video understanding, edit plan, publish copy.
# - Deepgram: transcript-backed subtitles.
# - Shotstack: final render.
# - Vizard: optional experimental all-in-one clip editing backend.
# - Runway/fal: optional enhancement routes for generated/assisted visuals.
# Toggle Clip Editor renderer: shotstack (default) or vizard.
# Set CLIP_EDITOR_RENDER_BACKEND=vizard in Vercel to use only Vizard for Clip Editor; unset it or set shotstack to return to the current pipeline.
# CLIP_EDITOR_RENDER_BACKEND=shotstack
GEMINI_API=your_google_ai_studio_key
DEEPGRAM_API_KEY=your_deepgram_api_key
# Optional Deepgram model override (default nova-3).
# CLIP_EDITOR_TRANSCRIPTION_MODEL=nova-3
# Optional Gemini planner override (default gemini-2.5-flash).
# CLIP_EDITOR_PLAN_GEMINI_MODEL=gemini-2.5-flash

# DeepSeek — legacy optional fallback for weekly algorithm research.
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Algorithm research uses Gemini 2.5 Flash by default (same as tags/content analyzer).
# Optional override: ALGORITHM_GEMINI_MODEL=gemini-2.5-flash
# Dedicated key (falls back to GEMINI_API): GEMINI_ALGORITHM_API_KEY=your_google_ai_studio_key

# Shotstack — Clip Editor render engine (required for final video output).
SHOTSTACK_API_KEY=your_shotstack_api_key
# Aliases (same value): SHOTSTACK_API or SHOTSTACK_KEY
# If render returns HTTP 403 from Shotstack, the key does not match the API segment:
#   Sandbox/trial key → unset SHOTSTACK_STAGE or SHOTSTACK_STAGE=stage → .../edit/stage/render
#   Production key → SHOTSTACK_STAGE=v1 (or live/production) → .../edit/v1/render
# SHOTSTACK_STAGE=stage
# SHOTSTACK_STAGE=v1

# Runway — optional Clip Editor enhancement route.
RUNWAYML_API_SECRET=your_runway_api_secret
# Alias: RUNWAY_API=your_runway_api_secret

# Vizard — optional all-in-one Clip Editor backend. Required only when CLIP_EDITOR_RENDER_BACKEND=vizard.
VIZARDAI_API_KEY=your_vizard_api_key
# Alias: VIZARD_API_KEY=your_vizard_api_key
# Vizard subtitles can drift. Use deepgram-shotstack to let Vizard cut only, then add our own Deepgram/Shotstack captions.
# Requires DEEPGRAM_API_KEY and SHOTSTACK_API_KEY in addition to VIZARDAI_API_KEY.
# CLIP_EDITOR_VIZARD_CAPTION_MODE=vizard
# CLIP_EDITOR_VIZARD_CAPTION_MODE=deepgram-shotstack
# Optional: force Vizard source language instead of auto, e.g. en.
# CLIP_EDITOR_VIZARD_LANG=auto
# Optional: set 0 if Vizard silence removal makes cuts feel unnatural.
# CLIP_EDITOR_VIZARD_REMOVE_SILENCE=1
# Optional: use a saved Vizard template if you have one for branded overlays/layouts.
# CLIP_EDITOR_VIZARD_TEMPLATE_ID=123456
# Optional: let Vizard add B-roll where supported. Keep off for cheapest/most deterministic tests.
# CLIP_EDITOR_VIZARD_AUTO_BROLL=0

# fal — thumbnails/tags today; future Clip Editor assist providers can use the same key.
# FAL_KEY=your_fal_key

# Google API Key (optional - for entity extraction)
GOOGLE_API_KEY=your_google_api_key_here

# Resend — staff email when users submit Contact staff (Settings); same pattern as above (host env).
# https://resend.com/api-keys — verify your domain for RESEND_FROM_EMAIL in production
RESEND_API_KEY=re_xxxxxxxx
# Optional: defaults to bulletbait604@gmail.com
# FEEDBACK_NOTIFY_EMAIL=you@example.com
# Optional: must be from a domain verified in Resend (defaults to Resend sandbox sender)
# RESEND_FROM_EMAIL=Stream Dreams <noreply@yourdomain.com>
