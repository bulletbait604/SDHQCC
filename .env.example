# MongoDB Atlas Connection String (optional - if using MongoDB)
# Replace YOUR_PASSWORD with your actual MongoDB password
# Replace the cluster URL with your actual connection string from MongoDB Atlas
MONGODB_URI=mongodb+srv://hashy_user:YOUR_PASSWORD@hashy-cluster.xxxxx.mongodb.net/hashy_tags?retryWrites=true&w=majority

# Google API Key (for entity extraction)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API Key (for premium tier deep reasoning)
OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek API Key (for premium tier deep reasoning)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# GitHub Configuration for Cloud Tag Databases
# Set USE_CLOUD_DB=true to fetch tag databases from GitHub instead of local files
USE_CLOUD_DB=true
GITHUB_USERNAME=your-github-username
GITHUB_REPO=hashy-tag-databases
GITHUB_BRANCH=main
